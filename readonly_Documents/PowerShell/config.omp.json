{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "{{ .UserName }} ",
          "foreground": "lightBlue",
          "type": "session",
          "style": "plain"
        },
        {
          "options": {
            "style": "folder"
          },
          "template": "<black>in</> {{ .Path }} ",
          "foreground": "lightCyan",
          "type": "path",
          "style": "plain"
        },
        {
          "type": "jujutsu",
          "options": {
            "fetch_status": true
          },
          "template": "<black>at</> <b>{{ .ChangeID }}</b>{{ if .ClosestBookmarks }} <black>on</> {{ .ClosestBookmarks }}{{ end }} ",
          "foreground": "lightMagenta",
          "style": "plain"
        },
        {
          "options": {
            "commit_icon": "<yellow>\uf417 </>",
            "branch_icon": "<yellow>\ue0a0 </>"
          },
          "template": "<black>at</> {{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "lightYellow",
          "type": "git",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "❯",
          "foreground": "lightGreen",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 4,
  "final_space": true
}